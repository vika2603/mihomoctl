.nh
.TH "MIHOMOCTL" "1" "May 2026" "" ""

.SH NAME
mihomoctl - Control a local mihomo external-controller


.SH SYNOPSIS
\fBmihomoctl [--endpoint URL] [--secret VALUE|-s VALUE] [--json] [--timeout DURATION]  [flags]\fP


.SH DESCRIPTION
Control a local mihomo external-controller


.SH OPTIONS
\fB--endpoint\fP="http://127.0.0.1:9090"
	mihomo external-controller endpoint

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for mihomoctl

.PP
\fB--json\fP[=false]
	emit JSON output

.PP
\fB-s\fP, \fB--secret\fP=""
	mihomo secret; prefer MIHOMOCTL_SECRET to avoid shell history/process-list leaks

.PP
\fB--timeout\fP=5s
	request timeout


.SH SEE ALSO
\fBmihomoctl-cache(1)\fP, \fBmihomoctl-connections(1)\fP, \fBmihomoctl-dns(1)\fP, \fBmihomoctl-group(1)\fP, \fBmihomoctl-mode(1)\fP, \fBmihomoctl-providers(1)\fP, \fBmihomoctl-proxy(1)\fP, \fBmihomoctl-rules(1)\fP, \fBmihomoctl-status(1)\fP
