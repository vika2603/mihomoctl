.SH NAME
mihomoctl-connections-watch - Stream active connection snapshots from mihomo


.SH SYNOPSIS
\fBmihomoctl connections watch [flags]\fP


.SH DESCRIPTION
Stream active mihomo connection snapshots over WebSocket until interrupted. Filters are applied locally after each event is received.


.SH OPTIONS
\fB--filter\fP=""
	CLI-local substring filter against host, destination, source, or rule

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for watch

.PP
\fB--interval\fP=1s
	mihomo websocket poll interval

.PP
\fB--max-reconnect-attempts\fP=100
	maximum consecutive reconnect failures before exiting; 0 means unbounded

.PP
\fB--no-reconnect\fP[=false]
	do not reconnect after websocket disconnects


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--endpoint\fP="http://127.0.0.1:9090"
	mihomo external-controller endpoint

.PP
\fB--json\fP[=false]
	emit JSON output

.PP
\fB-s\fP, \fB--secret\fP=""
	mihomo secret; prefer MIHOMOCTL_SECRET to avoid shell history/process-list leaks

.PP
\fB--timeout\fP=5s
	request timeout


.SH SEE ALSO
\fBmihomoctl-connections(1)\fP
